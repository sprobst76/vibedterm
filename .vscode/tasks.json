{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: Windows Release",
      "type": "shell",
      "command": "flutter build windows --release",
      "options": {
        "cwd": "${workspaceFolder}/apps/ssh_client_app"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build: Android APK Release",
      "type": "shell",
      "command": "flutter build apk --release",
      "options": {
        "cwd": "${workspaceFolder}/apps/ssh_client_app"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Package: Windows ZIP",
      "type": "shell",
      "command": "Compress-Archive -Force -Path build/windows/x64/runner/Release/* -DestinationPath ../../vibedterm-windows-x64.zip && Write-Host 'Packaged: vibedterm-windows-x64.zip'",
      "options": {
        "cwd": "${workspaceFolder}/apps/ssh_client_app",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-Command"]
        }
      },
      "dependsOn": "Build: Windows Release",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Release: Tag and Push",
      "type": "shell",
      "command": "git tag ${input:tagName} && git push origin ${input:tagName}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run: Flutter Analyze",
      "type": "shell",
      "command": "flutter analyze",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run: All Tests",
      "type": "shell",
      "command": "melos run check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "tagName",
      "type": "promptString",
      "description": "Version tag (e.g. v0.5.0)",
      "default": "v0.5.0"
    }
  ]
}
